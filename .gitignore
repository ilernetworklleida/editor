# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# Entorno
.env
.env.*
!.env.example
*.log

# Videos pesados (no commitear)
input/*
!input/.gitkeep
output/*
!output/.gitkeep

# Musica (mp3 grandes, propia/libre del usuario)
music/*
!music/.gitkeep

# Branding (logos del usuario, archivos generados)
branding/*
!branding/.gitkeep

# Jobs del web UI (logs y metadata, no se commitean)
jobs/

# Schedules privadas (URLs, cron, etc. son tuyas)
schedules.json

# FastAPI / uvicorn
*.pid

# Cache modelos Whisper
.cache/

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db
desktop.ini
