# Editor web UI — variables de entorno.
# Copia este archivo a .env y rellena con tus credenciales.
# El servidor las lee al arrancar. Si NO defines ADMIN_PASS, no hay auth.

# Email del administrador (default: info@ilernetwork.com)
ADMIN_EMAIL=info@ilernetwork.com

# Contrase&ntilde;a del administrador (REQUERIDA para activar el login)
ADMIN_PASS=cambia-esto-por-algo-seguro

# Secret key para firmar las sesiones (32+ caracteres aleatorios).
# Si no se define, se genera uno random al arrancar (las sesiones existentes
# se invalidan en cada reinicio). Mejor define uno fijo.
EDITOR_SECRET=genera-aqui-un-string-largo-y-aleatorio-32-bytes-min

# Para Claude API smart highlights (opcional pero recomendado).
# La IA selecciona los N momentos mas virales del transcript en vez de
# usar la heuristica de densidad de palabras. Coste ~$0.05 por video.
# ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar (default claude-opus-4-7, el mas inteligente).
# Alternativas: claude-sonnet-4-6 (mas barato), claude-haiku-4-5 (mas rapido).
# HIGHLIGHTS_MODEL=claude-opus-4-7

# Webhook opcional: cuando un job termina (done o error) se hace POST
# con JSON. Compatible con Slack incoming webhooks, Discord, IFTTT y
# cualquier endpoint generico que acepte JSON.
# WEBHOOK_URL=https://hooks.slack.com/services/T00.../B00.../xxxx
# Para que el link al job sea clickable desde el receiver:
# WEBHOOK_PUBLIC_URL=https://editor.tu-dominio.com
