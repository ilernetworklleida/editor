# Editor web UI — variables de entorno opcionales.
# Copia este archivo a .env y rellena con tus credenciales.
# El servidor las lee al arrancar. Si NO defines estas dos, no hay auth.

# Usuario/password para HTTP Basic Auth (recomendado si expones a internet)
EDITOR_USER=admin
EDITOR_PASS=cambia-esto-por-algo-seguro
